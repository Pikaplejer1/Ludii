(define "CountPips"
    <Dice:values>
)

(define "RemoveAPiece" (move Remove (from)))

(define "MoveTo" ("NextSiteOnTrack" ("CountPips")))

(define "NumPieces" <NumPieces:num>)

//------------------------------------------------------------------------------

(game "20 Squares"
    (players 2) 
    (equipment { 
        (board 
            (merge 
                (rectangle 3 4) 
                (shift 0 1 (rectangle 1 12))
            )
            { 
            (track "Track1" "20,3,W,N1,E,End" P1 directed:True)
            (track "Track2" "21,12,W,S1,E,End" P2 directed:True)
            }
        )
        <Dice:type>
        (hand Each)
        (regions "Replay" <Replay:sites>)
        (regions "Safe" <Safe:sites>)
        
        (piece "UrPiece" Each
            (if <Escape:rule>
                "RemoveAPiece"
                (if ("IsNotOffBoard" ("MoveTo"))	
                    <Capture:rule>
                )
            )
        ) 
        
    }) 
    
    (rules 
        (start { 	
            (place "UrPiece1" (handSite P1) count:("NumPieces"))
            (place "UrPiece2" (handSite P2) count:("NumPieces"))
        })	
        
        (play ("RollMove" (if (!= (count Pips) 0) (or (forEach Piece) (forEach Piece container:(mover))))))
        
        (end ("EscapeWin"))
    )
)

//------------------------------------------------------------------------------

(option "NumPieces" <NumPieces> args:{ <num> }
    {
    (item "Seven" <7> "Seven Pieces.")* 
    (item "Five" <5> "Five Pieces.")
    }
)

(option "Dice" <Dice> args:{ <type> <values>}
    {
    (item "Seleucid" <(dice facesByDie:{{1 2 3 4} {0 1}} num:2)> 
        <(if (= 0 (face 23))
            (face 22)	
            (if (= 1 (face 22))
                (+ (face 22) 5)
                (if (= 2 (face 22))
                    (+ (face 22) 6)
                    (if (= 3 (face 22))
                        (+ (face 22) 7)
                        (+ (face 22) 10)
                    )
                )
            )
        )>
    "Seleucid Dice.")*
    
    (item "Tetrahedral" <("StickDice" 4)> 
        <(count Pips)>
    "Tetrahedral Dice.")
    
    (item "Astragali" <(dice facesByDie:{{1 2 3 4}} num:1 biased:{3710 3725 1271 1294})> 
        <(count Pips)>
    "Astragali Dice.")
    
    (item "Seleukid" <(dice facesByDie:{{1 2 3 5} {1 2 3 5}} num:2 biased:{3710 3725 1271 1294})> 
        <(count Pips)>
    "Seleukid Dice.")
    
    (item "D6" <(dice d:6 num:1)> 
        <(count Pips)>
    "One D6 Dice.")
    }
)

(option "Replay" <Replay> args:{ <sites> }
    {
    (item "Corners" <(sites {"A1" "A3"})> "Replay Sites are only on the corners.")* 
    (item "All" <(sites {"A1" "A3" "D2" "H2" "L2"})> "All rosettes are replay sites.")
    (item "None" <(sites {})> "No replay sites.")
    }
)

(option "Safe" <Safe> args:{ <sites> }
    {
    (item "Middle" <(sites {"D2" "H2" "L2"})> "Safe Sites are only on the middle.")* 
    (item "None" <(sites {})> "No Safe Sites.")
    }
)

(option "Capture" <Capture> args:{ <rule> }
    {
    (item "Yes" <
        (if (or
                (is Empty ("MoveTo"))
                (and 
                    (not ("IsFriendAt" ("MoveTo"))) 
                    (not (is In ("MoveTo") (sites "Safe")))
                )
            )
            (move 
                (from) 
                (to 
                    ("MoveTo")
                    ("HittingCapture" (handSite (who at:(to))))
                )
                (then ("ReplayInMovingOn" (sites "Replay")))
            )
        )
    > "Capture is allowed.")* 
    (item "No" <
        (if (is Empty ("MoveTo"))
            (move 
                (from) 
                (to 
                    ("MoveTo")
                )
                (then ("ReplayInMovingOn" (sites "Replay")))
            )
        )
    > "No Capture.")
    }
)

(option "Escape" <Escape> args:{ <rule> }
    {
    (item "End" <("IsEndTrack" "MoveTo")> "Remove a Piece in reaching a site +1 after the end.")* 
    (item "Off" <(or ("IsEndTrack" "MoveTo") ("IsOffBoard" "MoveTo"))> "Remove a Piece in reaching any site after the end.")
    }
)

